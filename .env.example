# Supabase project URL, for example:
# https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_URL=

# Public client key from Supabase. Use a publishable key when available,
# or the legacy anon key. Do not use the service_role/secret key in clients.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Clerk mobile auth. Clerk owns sign-in, sign-up, password recovery,
# and connected social providers.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID=
