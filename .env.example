# Supabase project URL, for example:
# https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_URL=

# Public client key from Supabase. Use a publishable key when available,
# or the legacy anon key. Do not use the service_role/secret key in clients.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mobile auth redirect. Use riftboundtracker:// for a development build or
# standalone app. Expo Go may require a temporary exp:// redirect URL.
EXPO_PUBLIC_AUTH_REDIRECT_URL=riftboundtracker://
